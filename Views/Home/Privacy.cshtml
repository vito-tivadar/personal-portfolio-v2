@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="privacy-policy">
    <div class="privacy-policy__header">
        <h1 class="privacy-policy__title">Privacy Policy</h1>
        <p class="privacy-policy__updated">Last updated: March 5, 2026</p>
    </div>

    <div class="privacy-policy__body">

        <div class="privacy-policy__section">
            <h2>Introduction</h2>
            <p>
                This website is a personal portfolio operated by Vito Tivadar.
                The purpose of this website is to present personal work and allow visitors to make contact.
            </p>
            <p>
                This Privacy Policy explains what information may be processed when you use this website.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Contact Form</h2>
            <p>
                This website provides a contact form that allows visitors to send a message to the website owner.
            </p>
            <p>When you submit the form, you may provide:</p>
            <ul>
                <li>your name</li>
                <li>your email address</li>
                <li>your message</li>
            </ul>
            <p>
                This information is not stored in any database on this website.
                The form only sends the message as an email to the website owner so they can respond to your inquiry.
            </p>
            <p>
                The information you provide will only be used for communication related to your message.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Data Storage</h2>
            <p>
                This website does not store personal data on its servers or in a database.
            </p>
            <p>
                Messages sent through the contact form are delivered via email and may remain stored
                in the email inbox solely for communication purposes.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Analytics and Third-Party Services</h2>
            <p>
                This website uses Google Analytics, implemented through Google Tag Manager,
                to understand how visitors interact with the website.
            </p>
            <p>These services may collect information such as:</p>
            <ul>
                <li>pages visited</li>
                <li>approximate location (country or region)</li>
                <li>device and browser information</li>
                <li>interaction with website content</li>
            </ul>
            <p>
                The website owner does not control how these third-party services process data.
                The collected information is used only for website analytics and improvement.
            </p>
            <p>
                For more information about how Google handles data, please refer to
                <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">
                    Google's privacy policy
                </a>.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Cookies</h2>
            <p>
                This website does not intentionally use cookies.
            </p>
            <p>
                However, third-party services integrated into the website may use their own
                technologies for analytics or functionality.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Data Sharing</h2>
            <p>
                The website owner does not sell, share, or distribute personal information.
            </p>
            <p>
                Any data processing performed by third-party services is governed by their own privacy policies.
            </p>
        </div>

        <div class="privacy-policy__section">
            <h2>Contact</h2>
            <p>If you have questions regarding this Privacy Policy, you may contact:</p>
            <address>
                <strong>Vito Tivadar</strong><br />
                Email: <a href="mailto:your@email.com">your@email.com</a><br />
                Website: <a href="https://yourdomain.com" target="_blank" rel="noopener noreferrer">yourdomain.com</a>
            </address>
        </div>

    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/app/components/privacy.css" asp-append-version="true" />
}
